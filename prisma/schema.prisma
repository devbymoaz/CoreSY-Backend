// Prisma schema for CoreSY backend
// Defines database models for authentication and user management

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum SubscriptionTier {
  FREE
  PREMIUM
  ENTERPRISE
}

enum RoleStatus {
  ACTIVE
  INACTIVE
}

enum PermissionStatus {
  ACTIVE
  INACTIVE
}

enum BusinessStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
  INACTIVE
  ACTIVE
}

enum BusinessType {
  RESTAURANT
  CAFE
  BAR
  MEDICAL_CLINIC
  HOSPITAL
  DENTAL_CLINIC
  PHARMACY
  BEAUTY_SALON
  SPA
  GYM
  SPORTS_CLUB
  ENTERTAINMENT_CENTER
  JUICE_SHOP
  SWEET_SHOP
  SUPERMARKET
  RETAIL_STORE
  OTHER
}

enum BranchStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
  CLOSED
}

enum ServiceStatus {
  DRAFT
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
  ARCHIVED
}

enum ServiceType {
  RESTAURANT
  CAFE
  BAR
  MEDICAL_CONSULTATION
  DENTAL_CONSULTATION
  LABORATORY
  PHARMACY
  BEAUTY_SERVICE
  SPA_TREATMENT
  GYM_MEMBERSHIP
  SPORTS_ACTIVITY
  ENTERTAINMENT_ACTIVITY
  DELIVERY_PRODUCT
  RETAIL_PRODUCT
  OTHER
}

enum ServiceCategory {
  FOOD_AND_DRINKS
  MEDICAL
  HEALTHCARE
  BEAUTY
  FITNESS
  SPORTS
  ENTERTAINMENT
  RETAIL
  DELIVERY
  OTHER
}

enum CashierStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
  RESIGNED
  DELETED
}

enum SlotStatus {
  AVAILABLE
  FULL
  CLOSED
  CANCELLED
  INACTIVE
}

enum BookingType {
  RESERVATION
  APPOINTMENT
  WALK_IN
}

enum RecurringType {
  DAILY
  WEEKLY
  MONTHLY
  NONE
}

enum GenderRestriction {
  MALE
  FEMALE
  BOTH
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  EXPIRED
  REJECTED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CASH
  WALLET
}

enum BookingSource {
  MOBILE_APP
  WEB
  WALK_IN
  ADMIN
}


// Syrian governorates with unique codes for Pass ID generation
model Governorate {
  id             String     @id @default(uuid())
  name           String     @unique
  nameAr         String?    @map("name_ar")
  code           String     @unique
  passIdSequence Int        @default(0) @map("pass_id_sequence")
  isActive       Boolean    @default(true) @map("is_active")
  users          User[]
  businesses     Business[]
  branches       Branch[]
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  @@map("governorates")
}

// Application roles for RBAC - Enhanced
model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  displayName     String           @map("display_name")
  description     String?
  priority        Int              @default(10)
  isSystem        Boolean          @default(false) @map("is_system")
  status          RoleStatus       @default(ACTIVE)
  createdBy       String?          @map("created_by")
  updatedBy       String?          @map("updated_by")
  deletedAt       DateTime?        @map("deleted_at")
  users           User[]
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@index([name])
  @@index([status])
  @@index([priority])
  @@map("roles")
}

// Permissions for fine-grained access control
model Permission {
  id              String           @id @default(uuid())
  module          String
  name            String
  slug            String           @unique
  description     String?
  status          PermissionStatus @default(ACTIVE)
  deletedAt       DateTime?        @map("deleted_at")
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@index([module])
  @@index([slug])
  @@map("permissions")
}

// Pivot table for role-permission many-to-many relationship
model RolePermission {
  id           String     @id @default(uuid())
  roleId       String     @map("role_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// Pivot table for user-role many-to-many relationship
model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String   @map("role_id")
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, roleId])
  @@map("user_roles")
}

// Audit logs to track all admin operations
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  module    String
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([module])
  @@index([action])
  @@map("audit_logs")
}

// Core user account shared across CoreSY Pass, Care, and Go
model User {
  id                 String           @id @default(uuid())
  passId             String           @unique @map("pass_id")
  fullName           String           @map("full_name")
  email              String           @unique
  phoneNumber        String           @unique @map("phone_number")
  smartAssistantName String?          @map("smart_assistant_name")
  profileImage       String?          @map("profile_image")
  password           String
  emailVerified      Boolean          @default(false) @map("email_verified")
  phoneVerified      Boolean          @default(false) @map("phone_verified")
  status             UserStatus       @default(PENDING_VERIFICATION)
  subscription       SubscriptionTier @default(FREE)
  acceptTerms        Boolean          @default(true) @map("accept_terms")
  governorateId      String           @map("governorate_id")
  governorate        Governorate      @relation(fields: [governorateId], references: [id])
  // Keep for compatibility, but use UserRole for actual roles
  roleId             String           @map("role_id")
  role               Role             @relation(fields: [roleId], references: [id])
  userRoles          UserRole[]
  refreshTokens      RefreshToken[]
  auditLogs          AuditLog[]
  notifications      Notification[]
  businesses         Business[]
  bookings           Booking[]
  favoriteBusinesses FavoriteBusiness[]
  lastLogin          DateTime?        @map("last_login")
  createdBy          String?          @map("created_by")
  updatedBy          String?          @map("updated_by")
  deletedAt          DateTime?        @map("deleted_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@index([email])
  @@index([phoneNumber])
  @@index([status])
  @@map("users")
}

// Secure refresh token storage with rotation support
model RefreshToken {
  id        String   @id @default(uuid())
  jti       String   @unique
  tokenHash String   @map("token_hash")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// Notifications for admins
model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  type      String
  data      Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// Business (Establishment) model
model Business {
  id                 String         @id @default(uuid())
  name               String         @map("name")
  type               BusinessType   @map("type")
  category           String         @map("category")
  description        String         @map("description")
  ownerName          String         @map("owner_name")
  ownerEmail         String         @map("owner_email")
  ownerPhone         String         @map("owner_phone")
  businessEmail      String         @unique @map("business_email")
  businessPhone      String         @map("business_phone")
  logo               String?        @map("logo")
  coverImage         String?        @map("cover_image")
  registrationNumber String         @unique @map("registration_number")
  taxNumber          String?        @map("tax_number")
  website            String?        @map("website")
  governorateId      String         @map("governorate_id")
  governorate        Governorate    @relation(fields: [governorateId], references: [id])
  city               String         @map("city")
  address            String         @map("address")
  latitude           Decimal?       @map("latitude")
  longitude          Decimal?       @map("longitude")
  workingHours       Json?          @map("working_hours")
  facebook           String?        @map("facebook")
  instagram          String?        @map("instagram")
  whatsApp           String?        @map("whats_app")
  status             BusinessStatus @default(PENDING) @map("status")
  approvalDate       DateTime?      @map("approval_date")
  approvedBy         String?        @map("approved_by")
  ownerId            String         @map("owner_id")
  owner              User           @relation(fields: [ownerId], references: [id])
  branches           Branch[]
  services           Service[]
  cashiers           Cashier[]
  slots              Slot[]
  bookings           Booking[]
  favoriteBusinesses FavoriteBusiness[]
  createdBy          String?        @map("created_by")
  updatedBy          String?        @map("updated_by")
  deletedAt          DateTime?      @map("deleted_at")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  @@index([name])
  @@index([status])
  @@index([type])
  @@index([ownerId])
  @@map("businesses")
}

// Business Branch model
model Branch {
  id               String       @id @default(uuid())
  name             String       @map("name")
  code             String       @unique @map("code")
  businessId       String       @map("business_id")
  business         Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type             String       @map("type")
  description      String?      @map("description")
  governorateId    String       @map("governorate_id")
  governorate      Governorate  @relation(fields: [governorateId], references: [id])
  city             String       @map("city")
  address          String       @map("address")
  latitude         Decimal?     @map("latitude")
  longitude        Decimal?     @map("longitude")
  googleMapLink    String?      @map("google_map_link")
  contactEmail     String?      @map("contact_email")
  contactPhone     String?      @map("contact_phone")
  whatsAppNumber   String?      @map("whats_app_number")
  workingDays      Json?        @map("working_days")
  openingTime      String?      @map("opening_time")
  closingTime      String?      @map("closing_time")
  emergencyContact String?      @map("emergency_contact")
  image            String?      @map("image")
  coverImage       String?      @map("cover_image")
  status           BranchStatus @default(PENDING) @map("status")
  isMain           Boolean      @default(false) @map("is_main")
  services         Service[]
  cashiers         Cashier[]
  slots            Slot[]
  bookings         Booking[]
  createdBy        String?      @map("created_by")
  updatedBy        String?      @map("updated_by")
  deletedAt        DateTime?    @map("deleted_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@index([name])
  @@index([code])
  @@index([businessId])
  @@index([status])
  @@index([governorateId])
  @@map("branches")
}

// Business Service model
model Service {
  id                  String         @id @default(uuid())
  name                String       @map("name")
  code                String       @unique @map("code")
  businessId          String       @map("business_id")
  business            Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branchId            String       @map("branch_id")
  branch              Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category            ServiceCategory @map("category")
  type                ServiceType   @map("type")
  description         String       @map("description")
  shortDescription    String?      @map("short_description")
  price               Decimal      @db.Decimal(10, 2) @map("price")
  discountPercentage   Decimal?     @db.Decimal(5, 2) @map("discount_percentage")
  coresyDiscount      Decimal?     @db.Decimal(5, 2) @map("coresy_discount")
  platformFee         Decimal?     @db.Decimal(5, 2) @map("platform_fee")
  duration            Int?         @map("duration") // In minutes
  maxCapacity         Int?         @map("max_capacity")
  bookingRequired     Boolean      @default(false) @map("booking_required")
  appointmentRequired Boolean      @default(false) @map("appointment_required")
  deliveryAvailable    Boolean      @default(false) @map("delivery_available")
  isFeatured          Boolean      @default(false) @map("is_featured")
  serviceImage         String?      @map("service_image")
  galleryImages       String[]     @map("gallery_images")
  status              ServiceStatus @default(DRAFT) @map("status")
  createdBy           String?      @map("created_by")
  updatedBy           String?      @map("updated_by")
  deletedAt           DateTime?    @map("deleted_at")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  @@index([name])
  @@index([code])
  @@index([businessId])
  @@index([branchId])
  @@index([status])
  @@index([category])
  @@index([type])
  @@index([isFeatured])
  slots            Slot[]
  bookings         Booking[]
  @@map("services")
}

// Slot model
model Slot {
  id                 String          @id @default(uuid())
  serviceId          String          @map("service_id")
  service            Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  businessId         String          @map("business_id")
  business           Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branchId           String          @map("branch_id")
  branch             Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  slotDate           DateTime        @map("slot_date")
  dayOfWeek          Int             @map("day_of_week") // 0 = Sunday, 6 = Saturday
  startTime          String          @map("start_time") // "HH:MM"
  endTime            String          @map("end_time") // "HH:MM"
  duration           Int             @map("duration") // in minutes
  maxCapacity        Int             @map("max_capacity")
  remainingCapacity  Int             @map("remaining_capacity")
  bookingType        BookingType     @map("booking_type")
  genderRestriction  GenderRestriction? @map("gender_restriction")
  minAge             Int?            @map("min_age")
  maxAge             Int?            @map("max_age")
  isRecurring        Boolean         @default(false) @map("is_recurring")
  recurringType      RecurringType   @default(NONE) @map("recurring_type")
  recurringEndDate   DateTime?       @map("recurring_end_date")
  status             SlotStatus      @default(AVAILABLE) @map("status")
  createdBy          String?         @map("created_by")
  updatedBy          String?         @map("updated_by")
  deletedAt          DateTime?       @map("deleted_at")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  @@index([serviceId])
  @@index([businessId])
  @@index([branchId])
  @@index([slotDate])
  @@index([status])
  @@index([bookingType])
  bookings           Booking[]
  @@map("slots")
}
model Cashier {
  id               String       @id @default(uuid())
  fullName         String       @map("full_name")
  employeeId       String       @unique @map("employee_id")
  email            String       @unique
  phoneNumber      String       @unique @map("phone_number")
  password         String
  businessId       String       @map("business_id")
  business         Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branchId         String       @map("branch_id")
  branch           Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  profileImage     String?      @map("profile_image")
  status           CashierStatus @default(PENDING) @map("status")
  joiningDate      DateTime?    @map("joining_date")
  lastLogin        DateTime?    @map("last_login")
  createdBy        String?      @map("created_by")
  updatedBy        String?      @map("updated_by")
  deletedAt        DateTime?    @map("deleted_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@index([fullName])
  @@index([employeeId])
  @@index([email])
  @@index([phoneNumber])
  @@index([businessId])
  @@index([branchId])
  @@index([status])
  @@map("cashiers")
}

// Booking model
model Booking {
  id                 String         @id @default(uuid())
  bookingNumber      String         @unique @map("booking_number")
  customerId         String         @map("customer_id")
  customer           User           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  businessId         String         @map("business_id")
  business           Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branchId           String         @map("branch_id")
  branch             Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  serviceId          String         @map("service_id")
  service            Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  slotId             String         @map("slot_id")
  slot               Slot           @relation(fields: [slotId], references: [id], onDelete: Cascade)
  bookingType        BookingType    @map("booking_type")
  reservationDate    DateTime       @map("reservation_date")
  startTime          String         @map("start_time")
  endTime            String         @map("end_time")
  numberOfGuests     Int            @map("number_of_guests")
  specialInstructions String?       @map("special_instructions")
  bookingSource      BookingSource  @default(MOBILE_APP) @map("booking_source")
  paymentMethod      String?        @map("payment_method")
  paymentStatus      PaymentStatus  @default(PENDING) @map("payment_status")
  status             BookingStatus  @default(PENDING)
  qrCode             String?        @map("qr_code")
  cancellationReason String?        @map("cancellation_reason")
  createdBy          String?        @map("created_by")
  updatedBy          String?        @map("updated_by")
  deletedAt          DateTime?      @map("deleted_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@index([bookingNumber])
  @@index([customerId])
  @@index([businessId])
  @@index([branchId])
  @@index([serviceId])
  @@index([slotId])
  @@index([status])
  @@index([paymentStatus])
  @@index([reservationDate])
  @@index([bookingType])
  @@map("bookings")
}

// Favorite Business model
model FavoriteBusiness {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId  String   @map("business_id")
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([userId, businessId])
  @@index([userId])
  @@index([businessId])
  @@map("favorite_businesses")
}
